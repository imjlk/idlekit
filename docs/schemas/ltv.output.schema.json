{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "idlekit/ltv-output-v1",
  "type": "object",
  "required": ["scenario", "horizons", "summary", "_meta"],
  "properties": {
    "scenario": { "type": "string" },
    "horizons": { "type": "array" },
    "insights": { "type": "object" },
    "summary": {
      "type": "object",
      "required": ["at30m", "at90d"],
      "properties": {
        "at30m": { "type": ["object", "null"] },
        "at90d": { "type": ["object", "null"] }
      }
    },
    "_meta": {
      "type": "object",
      "required": ["command", "contractVersion", "schemaRef", "cliVersion", "gitSha", "scenarioHash", "pluginDigest"],
      "properties": {
        "command": { "const": "ltv" },
        "contractVersion": { "type": "string" },
        "schemaRef": { "const": "docs/schemas/ltv.output.schema.json" },
        "cliVersion": { "type": "string" },
        "gitSha": { "type": "string" },
        "runId": { "type": "string" },
        "seed": { "type": "number" },
        "scenarioHash": { "type": "string" },
        "pluginDigest": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
