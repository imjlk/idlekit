{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "idlekit/calibrate-output-v1",
  "type": "object",
  "required": ["ok", "source", "sample", "monetization", "scenarioPatch", "_meta"],
  "properties": {
    "ok": { "const": true },
    "source": { "type": "string" },
    "sample": {
      "type": "object",
      "required": ["rows", "users"],
      "properties": {
        "rows": { "type": "number" },
        "users": { "type": "number" }
      }
    },
    "monetization": {
      "type": "object",
      "required": ["retention", "revenue", "acquisition", "uncertainty"],
      "properties": {
        "retention": { "type": "object" },
        "revenue": { "type": "object" },
        "acquisition": { "type": "object" },
        "uncertainty": {
          "type": "object",
          "required": ["correlation"],
          "properties": {
            "correlation": { "type": "object" }
          }
        }
      }
    },
    "scenarioPatch": { "type": "object" },
    "_meta": {
      "type": "object",
      "required": ["command", "contractVersion", "schemaRef", "cliVersion", "gitSha", "telemetryHash", "pluginDigest"],
      "properties": {
        "command": { "const": "calibrate" },
        "contractVersion": { "type": "string" },
        "schemaRef": { "const": "docs/schemas/calibrate.output.schema.json" },
        "cliVersion": { "type": "string" },
        "gitSha": { "type": "string" },
        "telemetryHash": { "type": "string" },
        "pluginDigest": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
