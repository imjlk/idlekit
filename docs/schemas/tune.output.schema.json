{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "idlekit/tune-output-v1",
  "type": "object",
  "required": ["ok", "report", "_meta"],
  "properties": {
    "ok": { "type": "boolean" },
    "report": {
      "type": "object",
      "required": ["best", "top", "tried"],
      "properties": {
        "best": { "type": "object" },
        "top": { "type": "array" },
        "tried": { "type": "number" }
      }
    },
    "insights": { "type": "object" },
    "_meta": {
      "type": "object",
      "required": [
        "command",
        "contractVersion",
        "schemaRef",
        "cliVersion",
        "gitSha",
        "scenarioHash",
        "tuneSpecHash",
        "pluginDigest"
      ],
      "properties": {
        "command": { "const": "tune" },
        "contractVersion": { "type": "string" },
        "schemaRef": { "const": "docs/schemas/tune.output.schema.json" },
        "cliVersion": { "type": "string" },
        "gitSha": { "type": "string" },
        "runId": { "type": "string" },
        "seed": { "type": "number" },
        "scenarioHash": { "type": "string" },
        "tuneSpecHash": { "type": "string" },
        "pluginDigest": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
