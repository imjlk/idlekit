{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "idlekit/compare-output-v2",
  "type": "object",
  "oneOf": [
    {
      "required": ["metric", "better", "detail", "measured", "_meta"],
      "properties": {
        "metric": { "type": "string" },
        "better": { "type": "string" },
        "detail": { "type": "object" },
        "measured": { "type": "object" },
        "insights": {
          "type": "object",
          "required": ["summary", "improved", "regressed", "drivers"],
          "properties": {
            "summary": { "type": "string" },
            "improved": { "type": "array", "items": { "type": "string" } },
            "regressed": { "type": "array", "items": { "type": "string" } },
            "drivers": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["key", "winner", "summary"],
                "properties": {
                  "key": {
                    "enum": [
                      "endNetWorth",
                      "droppedRate",
                      "etaToTargetWorth",
                      "timeToMilestone",
                      "visibleChangesPerMinute",
                      "maxNoRewardGapSec"
                    ]
                  },
                  "winner": { "enum": ["a", "b"] },
                  "summary": { "type": "string" }
                }
              }
            }
          }
        },
        "_meta": { "$ref": "#/$defs/meta" }
      }
    },
    {
      "required": ["bundle", "results", "_meta"],
      "properties": {
        "bundle": { "enum": ["economy", "design", "full"] },
        "milestoneKey": { "type": "string" },
        "summary": {
          "type": "object",
          "properties": {
            "winners": {
              "type": "object",
              "required": ["a", "b", "tie"],
              "properties": {
                "a": { "type": "number" },
                "b": { "type": "number" },
                "tie": { "type": "number" }
              }
            }
          }
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["metric", "better", "detail", "measured"],
            "properties": {
              "metric": { "type": "string" },
              "better": { "type": "string" },
              "detail": { "type": "object" },
              "measured": { "type": "object" },
              "insights": { "type": "object" }
            }
          }
        },
        "_meta": { "$ref": "#/$defs/meta" }
      }
    }
  ],
  "$defs": {
    "meta": {
      "type": "object",
      "required": ["command", "contractVersion", "schemaRef", "cliVersion", "gitSha", "scenarioHash", "pluginDigest"],
      "properties": {
        "command": { "const": "compare" },
        "contractVersion": { "type": "string" },
        "schemaRef": { "const": "docs/schemas/compare.output.schema.json" },
        "cliVersion": { "type": "string" },
        "gitSha": { "type": "string" },
        "runId": { "type": "string" },
        "seed": { "type": "number" },
        "scenarioHash": {
          "type": "object",
          "required": ["a", "b"],
          "properties": {
            "a": { "type": "string" },
            "b": { "type": "string" }
          }
        },
        "pluginDigest": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
