{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "idlekit/compare-output-v1",
  "type": "object",
  "required": ["metric", "better", "detail", "measured", "_meta"],
  "properties": {
    "metric": { "type": "string" },
    "better": { "type": "string" },
    "detail": { "type": "object" },
    "measured": { "type": "object" },
    "_meta": {
      "type": "object",
      "required": ["command", "scenarioHash"],
      "properties": {
        "command": { "const": "compare" },
        "scenarioHash": {
          "type": "object",
          "required": ["a", "b"],
          "properties": {
            "a": { "type": "string" },
            "b": { "type": "string" }
          }
        }
      }
    }
  }
}
