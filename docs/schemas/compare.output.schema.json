{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "idlekit/compare-output-v1",
  "type": "object",
  "required": ["metric", "better", "detail", "measured", "_meta"],
  "properties": {
    "metric": { "type": "string" },
    "better": { "type": "string" },
    "detail": { "type": "object" },
    "measured": { "type": "object" },
    "insights": { "type": "object" },
    "_meta": {
      "type": "object",
      "required": ["command", "contractVersion", "schemaRef", "cliVersion", "gitSha", "scenarioHash", "pluginDigest"],
      "properties": {
        "command": { "const": "compare" },
        "contractVersion": { "type": "string" },
        "schemaRef": { "const": "docs/schemas/compare.output.schema.json" },
        "cliVersion": { "type": "string" },
        "gitSha": { "type": "string" },
        "runId": { "type": "string" },
        "seed": { "type": "number" },
        "scenarioHash": {
          "type": "object",
          "required": ["a", "b"],
          "properties": {
            "a": { "type": "string" },
            "b": { "type": "string" }
          }
        },
        "pluginDigest": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
