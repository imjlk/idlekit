{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "idlekit/eta-output-v1",
  "type": "object",
  "required": ["reached", "seconds", "mode", "_meta"],
  "properties": {
    "reached": { "type": "boolean" },
    "seconds": { "type": "number" },
    "mode": { "type": "string" },
    "_meta": {
      "type": "object",
      "required": ["command", "contractVersion", "schemaRef", "cliVersion", "gitSha", "scenarioHash", "pluginDigest"],
      "properties": {
        "command": { "const": "eta" },
        "contractVersion": { "type": "string" },
        "schemaRef": { "const": "docs/schemas/eta.output.schema.json" },
        "cliVersion": { "type": "string" },
        "gitSha": { "type": "string" },
        "runId": { "type": "string" },
        "seed": { "type": "number" },
        "scenarioHash": { "type": "string" },
        "pluginDigest": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
