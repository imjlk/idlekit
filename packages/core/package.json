{
  "name": "@idlekit/core",
  "version": "0.1.0",
  "description": "Bun-first scenario compilation, simulation, analysis, and reporting for idle game economies.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imjlk/idlekit.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/imjlk/idlekit/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/imjlk/idlekit/issues"
  },
  "keywords": [
    "bun",
    "idle-game",
    "incremental-game",
    "economy-simulator",
    "simulation",
    "game-balancing",
    "economy-design"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test src",
    "prepack": "bun run build && bun ../../tools/package-manifest.ts prepare",
    "postpack": "bun ../../tools/package-manifest.ts restore"
  },
  "dependencies": {
    "@idlekit/money": "workspace:*",
    "typia": "^12.0.2",
    "zod": "^4.1.12"
  }
}
