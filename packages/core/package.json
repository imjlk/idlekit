{
  "name": "@idlekit/core",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "tsconfig.build.json",
    "tsconfig.json"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test src",
    "prepack": "bun run build && bun ../../tools/package-manifest.ts prepare",
    "postpack": "bun ../../tools/package-manifest.ts restore"
  },
  "dependencies": {
    "@idlekit/money": "workspace:*",
    "typia": "^9.7.2",
    "zod": "^4.1.12"
  }
}
