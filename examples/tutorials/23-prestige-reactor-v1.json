{
  "schemaVersion": 1,
  "meta": {
    "id": "prestige-reactor-v1",
    "title": "Prestige Reactor V1",
    "description": "Prestige-heavy design library example focused on repeated reactor resets, multiplier carryover, and first-prestige timing.",
    "tags": ["design-library", "prestige-heavy", "plugin", "worked-example"]
  },
  "unit": {
    "code": "PLASMA",
    "symbol": "P"
  },
  "policy": {
    "mode": "accumulate",
    "maxLogGap": 14
  },
  "model": {
    "id": "plugin.generators",
    "version": 1,
    "params": {
      "baseIncome": "1.8",
      "producerIncome": "2.4",
      "producerBaseCost": "22",
      "producerCostGrowth": 1.12,
      "upgradeBaseCost": "130",
      "upgradeGrowth": 1.55,
      "upgradeIncomeBoost": 0.22,
      "gemExchangeCost": "520",
      "prestigeRequirement": "3500",
      "prestigeStarterCash": "90",
      "prestigeMultiplierPerPoint": 0.22
    }
  },
  "initial": {
    "t": 0,
    "wallet": {
      "unit": "PLASMA",
      "amount": "80",
      "bucket": "0"
    },
    "vars": {
      "producers": 0,
      "upgrades": 0,
      "gems": 0
    },
    "prestige": {
      "count": 0,
      "points": "0",
      "multiplier": "1"
    }
  },
  "clock": {
    "stepSec": 1,
    "durationSec": 14400
  },
  "strategy": {
    "id": "plugin.producerFirst",
    "params": {
      "schemaVersion": 1,
      "allowUpgrade": true,
      "preferUpgradeAtProducers": 6,
      "allowPrestige": true,
      "preferPrestigeAtProducers": 12
    }
  },
  "design": {
    "intent": "scale-fantasy",
    "sessionPattern": {
      "id": "weekend-marathon",
      "days": 14
    }
  },
  "analysis": {
    "growth": {
      "windowSec": 300
    },
    "experience": {
      "series": "netWorth",
      "draws": 1,
      "quantiles": [0.1, 0.5, 0.9]
    }
  },
  "monetization": {
    "cohorts": { "baseUsers": 10000 },
    "retention": {
      "d1": 0.44,
      "d7": 0.24,
      "d30": 0.11,
      "d90": 0.05,
      "longTailDailyDecay": 0.018
    },
    "revenue": {
      "payerConversion": 0.03,
      "arppuDaily": 0.78,
      "adArpDau": 0.02,
      "platformFeeRate": 0.3,
      "grossMarginRate": 0.92,
      "progressionRevenueLift": 0.58,
      "progressionLogSpan": 6
    },
    "acquisition": { "cpi": 1.85 }
  },
  "outputs": {
    "format": "json",
    "report": {
      "checkpointsSec": [300, 1800, 3600, 7200, 14400],
      "includeTrace": true,
      "traceEverySteps": 2,
      "includeGrowth": true,
      "includeUX": true
    }
  }
}
