{
  "schemaVersion": 1,
  "meta": {
    "id": "longrun-colony-v1",
    "title": "Longrun Colony V1",
    "description": "Longrun design library example focused on offline-heavy scaling, colony infrastructure, and 30d/90d worth checks.",
    "tags": ["design-library", "longrun", "plugin", "worked-example"]
  },
  "unit": {
    "code": "ALLOY",
    "symbol": "Al"
  },
  "policy": {
    "mode": "accumulate",
    "maxLogGap": 16
  },
  "model": {
    "id": "plugin.generators",
    "version": 1,
    "params": {
      "baseIncome": "2.8",
      "producerIncome": "5.4",
      "producerBaseCost": "55",
      "producerCostGrowth": 1.15,
      "upgradeBaseCost": "420",
      "upgradeGrowth": 1.75,
      "upgradeIncomeBoost": 0.26,
      "gemExchangeCost": "2400"
    }
  },
  "initial": {
    "t": 0,
    "wallet": {
      "unit": "ALLOY",
      "amount": "160",
      "bucket": "0"
    },
    "vars": {
      "producers": 0,
      "upgrades": 0,
      "gems": 0
    },
    "prestige": {
      "count": 0,
      "points": "0",
      "multiplier": "1"
    }
  },
  "clock": {
    "stepSec": 10,
    "durationSec": 86400
  },
  "strategy": {
    "id": "plugin.producerFirst",
    "params": {
      "schemaVersion": 1,
      "allowUpgrade": true,
      "preferUpgradeAtProducers": 10,
      "allowPrestige": false
    }
  },
  "design": {
    "intent": "scale-fantasy",
    "sessionPattern": {
      "id": "offline-heavy",
      "days": 30
    }
  },
  "analysis": {
    "growth": {
      "windowSec": 600
    },
    "experience": {
      "series": "netWorth",
      "draws": 1,
      "quantiles": [0.1, 0.5, 0.9]
    }
  },
  "sim": {
    "fast": true,
    "eventLog": {
      "enabled": false,
      "maxEvents": 0
    }
  },
  "monetization": {
    "cohorts": { "baseUsers": 12000 },
    "retention": {
      "d1": 0.39,
      "d7": 0.2,
      "d30": 0.11,
      "d90": 0.055,
      "longTailDailyDecay": 0.016
    },
    "revenue": {
      "payerConversion": 0.034,
      "arppuDaily": 0.86,
      "adArpDau": 0.016,
      "platformFeeRate": 0.3,
      "grossMarginRate": 0.92,
      "progressionRevenueLift": 0.55,
      "progressionLogSpan": 7
    },
    "acquisition": { "cpi": 2.1 }
  },
  "outputs": {
    "format": "json",
    "report": {
      "checkpointsSec": [300, 1800, 7200, 21600, 86400],
      "includeTrace": true,
      "traceEverySteps": 6,
      "includeGrowth": true,
      "includeUX": true
    }
  }
}
