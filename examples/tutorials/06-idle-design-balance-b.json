{
  "schemaVersion": 1,
  "meta": {
    "id": "idle-design-balance-b",
    "title": "Idle Design Balance B (Upgrade Biased)",
    "description": "Counterfactual balance profile to compare against idle-design-v1",
    "tags": ["design-first", "idle", "plugin", "compare", "balance-b"]
  },
  "unit": {
    "code": "COIN",
    "symbol": "C"
  },
  "policy": {
    "mode": "accumulate",
    "maxLogGap": 14
  },
  "model": {
    "id": "plugin.generators",
    "version": 1,
    "params": {
      "baseIncome": "0.8",
      "producerIncome": "1.35",
      "producerBaseCost": "11",
      "producerCostGrowth": 1.13,
      "upgradeBaseCost": "90",
      "upgradeGrowth": 1.55,
      "upgradeIncomeBoost": 0.24,
      "gemExchangeCost": "780"
    }
  },
  "initial": {
    "t": 0,
    "wallet": {
      "unit": "COIN",
      "amount": "40",
      "bucket": "0"
    },
    "vars": {
      "producers": 0,
      "upgrades": 0,
      "gems": 0
    },
    "prestige": {
      "count": 0,
      "points": "0",
      "multiplier": "1"
    }
  },
  "clock": {
    "stepSec": 1,
    "durationSec": 2400
  },
  "strategy": {
    "id": "plugin.producerFirst",
    "params": {
      "schemaVersion": 1,
      "allowUpgrade": true,
      "preferUpgradeAtProducers": 8
    }
  },
  "design": {
    "intent": "strategic-optimization",
    "sessionPattern": {
      "id": "twice-daily",
      "days": 7
    }
  },
  "analysis": {
    "eta": {
      "mode": "simulate"
    },
    "growth": {
      "windowSec": 60
    },
    "experience": {
      "series": "netWorth",
      "draws": 1,
      "quantiles": [0.1, 0.5, 0.9]
    }
  },
  "monetization": {
    "cohorts": {
      "baseUsers": 10000
    },
    "retention": {
      "d1": 0.4,
      "d7": 0.18,
      "d30": 0.085,
      "d90": 0.038,
      "longTailDailyDecay": 0.022
    },
    "revenue": {
      "payerConversion": 0.032,
      "arppuDaily": 0.75,
      "adArpDau": 0.021,
      "platformFeeRate": 0.3,
      "grossMarginRate": 0.92,
      "progressionRevenueLift": 0.5,
      "progressionLogSpan": 6
    },
    "acquisition": {
      "cpi": 1.85
    },
    "uncertainty": {
      "enabled": true,
      "draws": 300,
      "quantiles": [0.5, 0.9],
      "seed": 19,
      "sigma": {
        "retention": 0.08,
        "conversion": 0.12,
        "arppu": 0.2,
        "ad": 0.15
      },
      "correlation": {
        "retentionConversion": 0.35,
        "retentionArppu": 0.28,
        "retentionAd": 0.18,
        "conversionArppu": 0.48,
        "conversionAd": 0.3,
        "arppuAd": 0.4
      }
    }
  },
  "outputs": {
    "format": "json",
    "report": {
      "checkpointsSec": [60, 300, 900, 1800, 2400],
      "includeTrace": true,
      "traceEverySteps": 1,
      "includeGrowth": true,
      "includeUX": true
    }
  }
}
