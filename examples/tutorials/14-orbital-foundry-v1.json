{
  "schemaVersion": 1,
  "meta": {
    "id": "orbital-foundry-v1",
    "title": "Orbital Foundry V1",
    "description": "Canonical worked example: a space-port manufacturing chain with fabricators, automation tiers, and recovered cores.",
    "tags": ["canonical", "worked-example", "plugin", "design-first", "orbital-foundry"]
  },
  "unit": {
    "code": "CREDIT",
    "symbol": "Cr"
  },
  "policy": {
    "mode": "accumulate",
    "maxLogGap": 14
  },
  "model": {
    "id": "plugin.generators",
    "version": 1,
    "params": {
      "baseIncome": "1.2",
      "producerIncome": "2.1",
      "producerBaseCost": "18",
      "producerCostGrowth": 1.125,
      "upgradeBaseCost": "155",
      "upgradeGrowth": 1.62,
      "upgradeIncomeBoost": 0.21,
      "gemExchangeCost": "980"
    }
  },
  "initial": {
    "t": 0,
    "wallet": {
      "unit": "CREDIT",
      "amount": "70",
      "bucket": "0"
    },
    "vars": {
      "producers": 0,
      "upgrades": 0,
      "gems": 0
    },
    "prestige": {
      "count": 0,
      "points": "0",
      "multiplier": "1"
    }
  },
  "clock": {
    "stepSec": 1,
    "durationSec": 3600
  },
  "strategy": {
    "id": "plugin.producerFirst",
    "params": {
      "schemaVersion": 1,
      "allowUpgrade": true,
      "preferUpgradeAtProducers": 6
    }
  },
  "design": {
    "intent": "strategic-optimization",
    "sessionPattern": {
      "id": "twice-daily",
      "days": 7
    }
  },
  "analysis": {
    "eta": {
      "mode": "simulate"
    },
    "growth": {
      "windowSec": 600
    },
    "experience": {
      "series": "netWorth",
      "draws": 1,
      "quantiles": [0.1, 0.5, 0.9]
    }
  },
  "monetization": {
    "cohorts": {
      "baseUsers": 14000
    },
    "retention": {
      "d1": 0.43,
      "d7": 0.21,
      "d30": 0.095,
      "d90": 0.042,
      "longTailDailyDecay": 0.019
    },
    "revenue": {
      "payerConversion": 0.031,
      "arppuDaily": 0.74,
      "adArpDau": 0.022,
      "platformFeeRate": 0.3,
      "grossMarginRate": 0.92,
      "progressionRevenueLift": 0.48,
      "progressionLogSpan": 6
    },
    "acquisition": {
      "cpi": 1.95
    },
    "uncertainty": {
      "enabled": true,
      "draws": 300,
      "quantiles": [0.5, 0.9],
      "seed": 23,
      "sigma": {
        "retention": 0.08,
        "conversion": 0.12,
        "arppu": 0.2,
        "ad": 0.15
      },
      "correlation": {
        "retentionConversion": 0.33,
        "retentionArppu": 0.27,
        "retentionAd": 0.16,
        "conversionArppu": 0.46,
        "conversionAd": 0.27,
        "arppuAd": 0.37
      }
    }
  },
  "outputs": {
    "format": "json",
    "report": {
      "checkpointsSec": [60, 300, 900, 1800, 3600],
      "includeTrace": true,
      "traceEverySteps": 1,
      "includeGrowth": true,
      "includeUX": true
    }
  }
}
